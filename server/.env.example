PORT=8787

# ── Core (required — Atlas won't respond without this) ──────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Voice (optional) ──────────────────────────────────────────────────────
# Without these, Atlas falls back to the browser's built-in speech synthesis.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Gmail + Google Calendar (optional, shared credentials) ───────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── RevenueCat (optional) ─────────────────────────────────────────────────
REVENUECAT_API_KEY=
REVENUECAT_PROJECT_ID=

# ── Buffer (optional) ──────────────────────────────────────────────────────
BUFFER_ACCESS_TOKEN=

# ── Meta / Instagram + Ads (optional, shared token) ───────────────────────
META_ACCESS_TOKEN=
META_IG_USER_ID=
META_AD_ACCOUNT_ID=

# See CONNECTORS.md for exactly how to obtain each value above.
