PORT=8787

# ── Chat (required — pick ONE, Atlas won't respond without one) ──────────
# Gemini has a genuinely free tier (no card needed): https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Daily request budget shown on the "POWER CELLS" HUD (Gemini Flash free tier is ~250/day).
GEMINI_DAILY_BUDGET=250

# Anthropic (paid, higher quality) — leave blank if using Gemini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: force a provider instead of auto-detecting from the keys above.
# Values: gemini | anthropic
CHAT_PROVIDER=

# ── Voice (optional) ──────────────────────────────────────────────────────
# Without these, Atlas falls back to the browser's built-in speech synthesis.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Gmail + Google Calendar (optional, shared credentials) ───────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Prism (data analysis — CSV/Excel upload, SQL, charts) ──────────────────
# URL of the deployed Prism API service (see ../../prism/api/main.py).
PRISM_API_URL=

# See CONNECTORS.md for exactly how to obtain each value above.
